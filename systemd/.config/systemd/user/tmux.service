[Unit]
Description=tmux default session (detached)
Documentation=man:tmux(1)

[Service]
Type=forking
Environment=DISPLAY=:0
Environment=PATH=/home/linuxbrew/.linuxbrew/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin
ExecStart=/home/linuxbrew/.linuxbrew/bin/tmux new-session -d

ExecStop=/home/felixngfender/.config/tmux/plugins/tmux-resurrect/scripts/save.sh
ExecStop=/home/linuxbrew/.linuxbrew/bin/tmux kill-server
KillMode=control-group

RestartSec=2

[Install]
WantedBy=default.target
